<UserControl
    x:Class="eKreta.UserControls.UserControlFelhasznalok"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:eKreta.UserControls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <StackPanel>
        <DataGrid x:Name="datagridFelhasznalok" Width="1100" Height="600"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  IsReadOnly="True"
                  SelectionChanged="datagridFelhasznalok_SelectionChanged"
                  >
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}">
                    
                </DataGridTextColumn>
                <DataGridTextColumn Header="Felh. név:" Binding="{Binding FelhasznaloNev}">
                    
                </DataGridTextColumn>
                <DataGridTextColumn Header="Teljes név:" Binding="{Binding TeljesNev}">
                    
                </DataGridTextColumn>
                <DataGridTextColumn Header="Szerepkör Id:" Binding="{Binding Szerepkor}">

                </DataGridTextColumn>
                <DataGridTextColumn Header="Szerepkör név:" Binding="{Binding SzerepkorNev}">
                    
                </DataGridTextColumn>

            </DataGrid.Columns>
        </DataGrid>
        <WrapPanel>
            <StackPanel>
                
            </StackPanel>
        </WrapPanel>
    </StackPanel>
</UserControl>
